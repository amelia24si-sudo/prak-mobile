<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#F4EAD5"
    tools:context=".tugas_p2.KalkulatorBangunan">

    <TextView
        android:id="@+id/tvTitleSegitiga"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1. Hitung Luas Segitiga"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#4A3B32"
        android:typeface="monospace"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etAlasSegitiga"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Masukkan Alas"
        android:inputType="numberDecimal"
        android:layout_marginTop="12dp"
        android:background="#E8D8C4"
        android:padding="12dp"
        android:textColor="#4A3B32"
        android:textColorHint="#8D7B68"
        android:typeface="monospace"
        app:layout_constraintTop_toBottomOf="@id/tvTitleSegitiga"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etTinggiSegitiga"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Masukkan Tinggi"
        android:inputType="numberDecimal"
        android:layout_marginTop="8dp"
        android:background="#E8D8C4"
        android:padding="12dp"
        android:textColor="#4A3B32"
        android:textColorHint="#8D7B68"
        android:typeface="monospace"
        app:layout_constraintTop_toBottomOf="@id/etAlasSegitiga"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnHitungSegitiga"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hitung Luas"
        android:layout_marginTop="12dp"
        android:textColor="#F4EAD5"
        android:typeface="monospace"
        app:backgroundTint="#6F4E37"
        app:cornerRadius="0dp"
        app:layout_constraintTop_toBottomOf="@id/etTinggiSegitiga"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvHasilSegitiga"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hasil Luas: -"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#D35400"
        android:typeface="monospace"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="@id/btnHitungSegitiga"
        app:layout_constraintBottom_toBottomOf="@id/btnHitungSegitiga"
        app:layout_constraintStart_toEndOf="@id/btnHitungSegitiga" />

    <TextView
        android:id="@+id/tvTitleBalok"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2. Hitung Volume Balok"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#4A3B32"
        android:typeface="monospace"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/btnHitungSegitiga"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etPanjangBalok"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Masukkan Panjang"
        android:inputType="numberDecimal"
        android:layout_marginTop="12dp"
        android:background="#E8D8C4"
        android:padding="12dp"
        android:textColor="#4A3B32"
        android:textColorHint="#8D7B68"
        android:typeface="monospace"
        app:layout_constraintTop_toBottomOf="@id/tvTitleBalok"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etLebarBalok"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Masukkan Lebar"
        android:inputType="numberDecimal"
        android:layout_marginTop="8dp"
        android:background="#E8D8C4"
        android:padding="12dp"
        android:textColor="#4A3B32"
        android:textColorHint="#8D7B68"
        android:typeface="monospace"
        app:layout_constraintTop_toBottomOf="@id/etPanjangBalok"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etTinggiBalok"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Masukkan Tinggi"
        android:inputType="numberDecimal"
        android:layout_marginTop="8dp"
        android:background="#E8D8C4"
        android:padding="12dp"
        android:textColor="#4A3B32"
        android:textColorHint="#8D7B68"
        android:typeface="monospace"
        app:layout_constraintTop_toBottomOf="@id/etLebarBalok"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnHitungBalok"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hitung Volume"
        android:layout_marginTop="12dp"
        android:textColor="#F4EAD5"
        android:typeface="monospace"
        app:backgroundTint="#6F4E37"
        app:cornerRadius="0dp"
        app:layout_constraintTop_toBottomOf="@id/etTinggiBalok"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvHasilBalok"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hasil Volume: -"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#D35400"
        android:typeface="monospace"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="@id/btnHitungBalok"
        app:layout_constraintBottom_toBottomOf="@id/btnHitungBalok"
        app:layout_constraintStart_toEndOf="@id/btnHitungBalok" />

</androidx.constraintlayout.widget.ConstraintLayout>