<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Home.HomeFragment">

    <View
        android:id="@+id/background_header"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:background="@drawable/bg_header_wave"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:subtitleTextColor="@android:color/white"
            app:titleTextColor="@android:color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/appBar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/textView5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/fjallaone_regular"
                android:gravity="center"
                android:text="Welcome!"
                android:textSize="77sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/textView4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Silahkan pilih...."
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textView5" />

            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/gridLayoutMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:padding="8dp"
                app:columnCount="4"
                app:columnOrderPreserved="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textView4"
                app:useDefaultMargins="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnp2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="P02"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnp3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="P03"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnp4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="P04"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnp5"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="P05"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnp7"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="P07"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnp9"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="P09"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnp10"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="P10"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnp13"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="P13"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal" />
            </androidx.gridlayout.widget.GridLayout>

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Logout"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/gridLayoutMenu" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvGallery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:padding="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btnLogout" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>